{
  "permissions": {
    "allow": [
      "Read(**)",
      "Glob(**)",
      "Grep(**)",
      "Write(app/**)",
      "Write(components/**)",
      "Write(db/**)",
      "Write(store/**)",
      "Write(utils/**)",
      "Write(__tests__/**)",
      "Write(e2e/**)",
      "Bash(npx tsc *)",
      "Bash(npx jest *)",
      "Bash(npx prettier *)",
      "Bash(npx eslint *)",
      "Bash(cat *)",
      "Bash(ls *)",
      "Bash(head *)",
      "Bash(tail *)",
      "Bash(wc *)",
      "Bash(find *)",
      "Bash(grep *)",
      "Bash(mkdir *)",
      "Bash(npm test *)",
      "Write(services/**)",
      "Write(lib/**)",
      "Write(docs/**)"
    ],
    "deny": [
      "Read(~/.ssh)",
      "Read(~/.aws)",
      "Read(~/.config/gh)",
      "Read(**/.env)",
      "Read(**/.env.*)",
      "Write(**/.env)",
      "Write(**/.env.*)",
      "Write(app.config.ts)",
      "Write(eas.json)",
      "Write(tsconfig.json)",
      "Bash(rm -rf *)",
      "Bash(git push *)",
      "Bash(git checkout main)",
      "Bash(eas build *)",
      "Bash(eas submit *)",
      "Bash(npx expo publish *)"
    ],
    "ask": ["Write(package.json)"]
  },
  "sandbox": {
    "failIfUnavailable": true,
    "autoAllowBashIfSandboxed": true,
    "filesystem": {
      "allowWrite": [".", "/tmp"],
      "denyRead": ["~/.ssh", "~/.aws", "~/.config/gh", "~/.npmrc", "~/.gitconfig"],
      "denyWrite": ["~/.ssh", "~/.aws", "~/.zshrc", "~/.bashrc"]
    },
    "network": {
      "allowedDomains": [
        "registry.npmjs.org",
        "world.openfoodfacts.org",
        "expo.dev",
        "api.expo.dev",
        "assets.expo.dev",
        "github.com"
      ],
      "allowLocalBinding": true
    }
  },
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume",
        "hooks": [
          {
            "type": "command",
            "command": "echo \"$(date '+%Y-%m-%d %H:%M') - Session started in $(pwd)\" >> ~/.claude/session-log.txt"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "FILE=$(jq -r '.tool_input.file_path // empty'); echo \"$FILE\" | grep -qE '(\\.env|app\\.config\\.ts|eas\\.json)' && echo 'Blocked: sensitive file requires manual review' >&2 && exit 2 || exit 0"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "CMD=$(jq -r '.tool_input.command // empty'); echo \"$CMD\" | grep -qE '(rm -rf|git push|eas build|eas submit|npx expo publish)' && echo 'Blocked: destructive command requires manual approval' >&2 && exit 2 || exit 0"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "FILE=$(jq -r '.tool_input.file_path // empty'); echo \"$FILE\" | grep -qE '\\.(ts|tsx)$' && npx prettier --write \"$FILE\" 2>/dev/null || exit 0"
          },
          {
            "type": "command",
            "command": "FILE=$(jq -r '.tool_input.file_path // empty'); echo \"$FILE\" | grep -qE '\\.test\\.(ts|tsx)$' && npx jest --no-watchman --passWithNoTests \"$FILE\" 2>&1 | tail -5 || exit 0",
            "async": true
          },
          {
            "type": "command",
            "command": "FILE=$(jq -r '.tool_input.file_path // empty'); echo \"$FILE\" | grep -qE '\\.(ts|tsx)$' && npx tsc --noEmit --skipLibCheck 2>&1 | head -20 || exit 0",
            "async": true
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "INPUT=$(cat); [ \"$(echo $INPUT | jq -r '.stop_hook_active')\" = 'true' ] && exit 0; terminal-notifier -message 'Claude finished' -title 'Claude Code' -sound default 2>/dev/null || osascript -e 'display notification \"Claude finished\" with title \"Claude Code\"'",
            "async": true
          }
        ]
      }
    ]
  }
}
